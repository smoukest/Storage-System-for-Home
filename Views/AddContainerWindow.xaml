<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="ApartmentInventory.Views.AddContainerWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		Title="Добавить коробку" Height="230" Width="430"
		WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
	<Grid Background="#F0F0F0">
		<StackPanel Margin="25" VerticalAlignment="Center">
			<TextBlock Text="Название коробки:" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>
			<TextBox x:Name="ContainerNameTextBox" Height="36" Padding="10" Margin="0,0,0,20" FontSize="12"/>
			<StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
				<Button x:Name="OkButton" Content="ОК" Width="80" Height="36" Click="OkButton_Click" Margin="0,0,10,0" FontSize="12"/>
				<Button Content="Отмена" Width="80" Height="36" IsCancel="True" FontSize="12"/>
			</StackPanel>
		</StackPanel>
	</Grid>
</Window>
