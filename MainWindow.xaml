<Window x:Class="_25._04.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_25._04"
        mc:Ignorable="d"
        Title="Учет вещей в квартире" Height="600" Width="1050" MinWidth="1050" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с кнопками -->
        <Border Grid.Row="0" Margin="15" Background="White" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ Добавить комнату" Width="140" Height="40" Click="AddRoomButton_Click"
                    Background="#4CAF50" Foreground="White" FontSize="12" Cursor="Hand" Margin="5"/>
            <Button Content="✎ Редактировать" Width="120" Height="40" Click="EditButton_Click" 
                    Background="#FFC107" Foreground="Black" FontSize="12" Cursor="Hand" Margin="5"/>
            <Button Content="🗑 Удалить" Width="100" Height="40" Click="DeleteButton_Click" 
                    Background="#F44336" Foreground="White" FontSize="12" Cursor="Hand" Margin="5"/>
            <Button Content="🔄 Обновить" Width="100" Height="40" Click="RefreshButton_Click" 
                    Background="#9C27B0" Foreground="White" FontSize="12" Cursor="Hand" Margin="5"/>
            <Separator Width="1" Margin="10,0"/>
            <Button x:Name="ExpandAllButton" Content="↕ Раскрыть все" Width="120" Height="40" Click="ExpandAllButton_Click" 
                    Background="#607D8B" Foreground="White" FontSize="12" Cursor="Hand" Margin="5"/>
            </StackPanel>
        </Border>

        <!-- Убрано TreeView, добавлен DataGrid для отображения предметов и Списки для комнат/контейнеров -->
        <Grid Grid.Row="1" Margin="15">
            <!-- Дерево-таблица (DataGrid) со скрывающейся иерархией -->
            <Border Background="White" BorderThickness="1" BorderBrush="#CCCCCC">
                <DataGrid x:Name="ItemsDataGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                          SelectionMode="Single" SelectionChanged="ItemsDataGrid_SelectionChanged"
                          PreviewMouseRightButtonDown="ItemsDataGrid_PreviewMouseRightButtonDown"
                          PreviewMouseLeftButtonDown="ItemsDataGrid_PreviewMouseLeftButtonDown"
                          CanUserAddRows="False" CanUserDeleteRows="False" RowHeight="30"
                          GridLinesVisibility="All" HorizontalGridLinesBrush="Black" VerticalGridLinesBrush="Black"
                          HeadersVisibility="Column" AlternatingRowBackground="#F0F0F0" RowBackground="#FFFFFF">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="" Binding="{Binding ExpandIndicator}" Width="30" >
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="250"/>
                        <DataGridTextColumn Header="Тип" Binding="{Binding ItemType}" Width="150"/>
                        <DataGridTextColumn Header="Местоположение" Binding="{Binding LocationInRoom}" Width="150"/>
                        <DataGridTextColumn Header="Контейнер/Комната" Binding="{Binding Container.Name}" Width="150"/>
                        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="200"/>
                        <DataGridTextColumn Header="Тип элемента" Binding="{Binding ElementType}" Width="*"/>
                    </DataGrid.Columns>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <Setter Property="Background" Value="White" />
                            <Setter Property="FontWeight" Value="Normal" />
                            <Style.Triggers>
                                <!-- Цвета по типам элементов -->
                                <DataTrigger Binding="{Binding ElementType}" Value="Комната">
                                    <Setter Property="Background" Value="#E8F5E9" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ElementType}" Value="Контейнер">
                                    <Setter Property="Background" Value="#FFF3E0" />
                                </DataTrigger>
                                <!-- Для вещей (ElementType="Вещь") оставляем чередование -->
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding ElementType}" Value="Вещь" />
                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=AlternationIndex}" Value="1" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Background" Value="#F0F0F0" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Border>
        </Grid>

        <!-- Нижняя панель с информацией -->
        <Border Grid.Row="2" Margin="15" Background="White" Padding="15">
            <StackPanel Orientation="Vertical">
                    <TextBlock x:Name="InfoTextBlock" Text="Выберите элемент для просмотра информации" 
                               FontSize="13" Foreground="#666" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
    </Grid>
</Window>
