<Window x:Class="_25._04.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_25._04"
        mc:Ignorable="d"
        Title="Учет вещей в квартире" Height="600" Width="900" 
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с кнопками -->
        <Border Grid.Row="0" Margin="15" Background="White" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ Добавить комнату" Width="140" Height="40" Click="AddRoomButton_Click"
                    Background="#4CAF50" Foreground="White" FontSize="12" Cursor="Hand" Margin="5"/>
            <Button Content="➕ Добавить контейнер" Width="160" Height="40" Click="AddContainerButton_Click" 
                    Background="#2196F3" Foreground="White" FontSize="12" Cursor="Hand" Margin="5"/>
            <Button Content="➕ Добавить вещь" Width="140" Height="40" Click="AddItemButton_Click" 
                    Background="#FF9800" Foreground="White" FontSize="12" Cursor="Hand" Margin="5"/>
            <Separator Width="1" Margin="10,0"/>
            <Button Content="✎ Редактировать" Width="120" Height="40" Click="EditButton_Click" 
                    Background="#FFC107" Foreground="Black" FontSize="12" Cursor="Hand" Margin="5"/>
            <Button Content="🗑 Удалить" Width="100" Height="40" Click="DeleteButton_Click" 
                    Background="#F44336" Foreground="White" FontSize="12" Cursor="Hand" Margin="5"/>
            <Button Content="🔄 Обновить" Width="100" Height="40" Click="RefreshButton_Click" 
                    Background="#9C27B0" Foreground="White" FontSize="12" Cursor="Hand" Margin="5"/>
            </StackPanel>
        </Border>

        <!-- TreeView с данными -->
        <Border Grid.Row="1" Margin="15" Background="White" BorderThickness="1" BorderBrush="#CCCCCC">
            <TreeView x:Name="ItemsTreeView" Margin="10" 
                      SelectedItemChanged="ItemsTreeView_SelectedItemChanged"/>
        </Border>

        <!-- Нижняя панель с информацией -->
        <Border Grid.Row="2" Margin="15" Background="White" Padding="15">
            <StackPanel Orientation="Vertical">
                    <TextBlock x:Name="InfoTextBlock" Text="Выберите элемент для просмотра информации" 
                               FontSize="13" Foreground="#666" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
    </Grid>
</Window>
